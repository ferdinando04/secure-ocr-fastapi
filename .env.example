# CONFIGURACIÓN ELITE OCR EXTRACTOR VENEZOLANO

# Identidad del Servicio
APP_NAME="OCR Venezolano Elite"
DEBUG=False

# SEGURIDAD (Obligatorio configurar en producción)
API_KEY="generar-clave-de-32-caracteres-para-seguridad-minima"

# CORS: Lista explícita de orígenes permitidos
# Ej: ["http://localhost:3000", "https://app-mi-negocio.com"]
ALLOWED_ORIGINS=["http://localhost:3000"]

# OCR PIPELINE
OCR_GPU=True
MIN_CONFIDENCE=0.50

# LÍMITES DE RECURSOS (Pragmatismo Pro)
MAX_FILE_SIZE_MB=5
MAX_IMAGE_RESOLUTION=4096

# INFRAESTRUCTURA
TMP_DIR="/tmp/ocr_service"
LOG_LEVEL=INFO
