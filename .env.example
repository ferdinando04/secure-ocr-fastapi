# Configuración del Servicio OCR
APP_NAME="OCR Venezolano Elite"
DEBUG=False

# SEGURIDAD (Obligatorio cambiar en producción)
API_KEY="generar-clave-de-32-caracteres-minimo"
# No usar wildcard en producción
ALLOWED_ORIGINS=["http://localhost:3000"]

# OCR
OCR_GPU=True
MIN_CONFIDENCE=0.50

# RECURSOS
MAX_FILE_SIZE_MB=5
MAX_IMAGE_RESOLUTION=4096

# LOGS
LOG_LEVEL=INFO
