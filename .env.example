# CONFIGURACIÓN SECURE ID-OCR API

# Metadata
APP_NAME="Secure ID-OCR API"
DEBUG=False

# SEGURIDAD (Obligatorio configurar en producción)
# Use 32+ caracteres aleatorios
API_KEY="configurar-una-key-robusta-aqui"
ALLOWED_ORIGINS=["http://localhost:3000"]

# OCR PIPELINE
OCR_GPU=True
MIN_CONFIDENCE=0.50

# RECURSOS
MAX_FILE_SIZE_MB=5
MAX_IMAGE_RESOLUTION=4096

# LOGS
LOG_LEVEL=INFO
TMP_DIR="/tmp/ocr_service"
