# Configuración del Servicio OCR
APP_NAME="OCR Venezolano Elite"
DEBUG=False

# SEGURIDAD 
# Generar una clave de al menos 32 caracteres
API_KEY=
# Especificar orígenes permitidos (e.g. ["http://localhost:3000"])
ALLOWED_ORIGINS=["*"]

# OCR
OCR_GPU=True
MIN_CONFIDENCE=0.50

# RECURSOS
MAX_FILE_SIZE_MB=5
MAX_IMAGE_RESOLUTION=4096

# LOGS
LOG_LEVEL=INFO
