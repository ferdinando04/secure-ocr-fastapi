# Configuración del Servicio OCR
APP_NAME="OCR Venezolano Elite"
DEBUG=False

# SEGURIDAD (Obligatorio cambiar en producción)
API_KEY="configurar-una-key-de-32-caracteres-minimo-aqui"

# CORS: Especificar orígenes de confianza (NUNCA usar * en prod con credenciales)
ALLOWED_ORIGINS=["http://localhost:3000"]

# OCR
OCR_GPU=True
MIN_CONFIDENCE=0.50

# RECURSOS
MAX_FILE_SIZE_MB=5
MAX_IMAGE_RESOLUTION=4096

# LOGS
LOG_LEVEL=INFO
